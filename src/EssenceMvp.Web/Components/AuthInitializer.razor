@inject AuthState Auth
@inject StorageService Storage
@inject SessionAuthenticationStateProvider AuthProvider

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var json = await Storage.GetAsync("essence_session");
            if (json is null) return;

            var session = System.Text.Json.JsonSerializer.Deserialize<AuthResponse>(
                json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (session?.Token is not null)
            {
                Auth.SetSession(session);
                AuthProvider.NotifySessionChanged();
            }
        }
        catch
        {
            // ignore corrupt storage
        }
    }
}
