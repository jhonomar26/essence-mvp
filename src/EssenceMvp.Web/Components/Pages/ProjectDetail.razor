@page "/projects/{Id:int}"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>@(_project?.Name ?? "Proyecto") — Essence</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        Debes <MudLink Href="/login">iniciar sesión</MudLink>.
    </MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_project is null)
{
    <MudStack Spacing="3">
        <MudAlert Severity="Severity.Error">Proyecto no encontrado.</MudAlert>
        <MudButton Href="/projects" StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text">
            Volver a proyectos
        </MudButton>
    </MudStack>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/projects" Size="Size.Small" />
            <MudText Typo="Typo.h5">@_project.Name</MudText>
            @if (!string.IsNullOrWhiteSpace(_project.Phase))
            {
                <MudChip Color="Color.Primary" Size="Size.Small">@_project.Phase</MudChip>
            }
        </MudStack>
        <MudStack Row="true" Spacing="1">
            <MudButton StartIcon="@Icons.Material.Filled.Edit" Variant="Variant.Outlined"
                       Size="Size.Small" OnClick="ToggleEdit">
                Editar
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Outlined"
                       Color="Color.Error" Size="Size.Small" OnClick="ConfirmDelete">
                Eliminar
            </MudButton>
        </MudStack>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(_project.Description))
    {
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">@_project.Description</MudText>
    }

    @if (_showEdit)
    {
        <MudPaper Elevation="1" Class="pa-5 mb-6">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Editar proyecto</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_editName" Label="Nombre *" Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_editPhase" Label="Fase" Variant="Variant.Outlined"
                               FullWidth="true" Clearable="true">
                        <MudSelectItem T="string" Value="@("Inception")">Inception</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Elaboration")">Elaboration</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Construction")">Construction</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Transition")">Transition</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_editDescription" Label="Descripción" Variant="Variant.Outlined"
                                  FullWidth="true" Lines="2" />
                </MudItem>
            </MudGrid>
            @if (!string.IsNullOrWhiteSpace(_editError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_editError</MudAlert>
            }
            <MudStack Row="true" Class="mt-4" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit" Disabled="@_saving">
                    @(_saving ? "Guardando..." : "Guardar cambios")
                </MudButton>
                <MudButton Variant="Variant.Text" OnClick="@(() => _showEdit = false)">Cancelar</MudButton>
            </MudStack>
        </MudPaper>
    }

    <MudText Typo="Typo.h6" Class="mb-1 mt-4">Estado de los Alphas</MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
        Creado: @_project.CreatedAt.ToString("dd/MM/yyyy HH:mm")
    </MudText>

    @foreach (var area in new[] { "Customer", "Solution", "Endeavor" })
    {
        var areaAlphas = _project.AlphaStatuses.Where(a => a.AreaOfConcern == area).ToList();
        if (areaAlphas.Count == 0) continue;

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle1" Color="@AreaColor(area)" Class="mb-3">
            @area
        </MudText>

        <MudGrid>
            @foreach (var alpha in areaAlphas)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1">
                        <MudCardContent Class="pa-4">
                            <MudText Typo="Typo.subtitle2" Class="mb-1">@alpha.AlphaName</MudText>
                            @if (alpha.CurrentStateNumber == 0)
                            {
                                <MudChip Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                    No iniciado
                                </MudChip>
                            }
                            else
                            {
                                <MudChip Color="Color.Success" Size="Size.Small">
                                    @if (!string.IsNullOrWhiteSpace(alpha.CurrentStateName))
                                    {
                                        @($"Estado {alpha.CurrentStateNumber}: {alpha.CurrentStateName}")
                                    }
                                    else
                                    {
                                        @($"Estado {alpha.CurrentStateNumber}")
                                    }
                                </MudChip>
                            }
                            <MudProgressLinear
                                Color="@(alpha.CurrentStateNumber == 0 ? Color.Default : Color.Success)"
                                Value="@(alpha.CurrentStateNumber / 6.0 * 100)"
                                Class="mt-3" Rounded="true" Size="Size.Small" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                @alpha.CurrentStateNumber / 6 estados
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

    <MudDivider Class="my-6" />

    <MudTooltip Text="Disponible en próxima versión">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Assignment" Disabled="true">
            Evaluar proyecto
        </MudButton>
    </MudTooltip>
}

@code {
    [Parameter] public int Id { get; set; }
    [Inject] ApiClient Api { get; set; } = default!;
    [Inject] AuthState Auth { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] IDialogService Dialog { get; set; } = default!;

    private ProjectDetailDto? _project;
    private bool _loading = true;

    private bool _showEdit;
    private string _editName = "";
    private string? _editPhase;
    private string _editDescription = "";
    private string? _editError;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnChange += OnAuthChanged;
        if (Auth.IsAuthenticated)
        {
            _project = await Api.GetProjectAsync(Id);
        }
        _loading = false;
    }

    private async void OnAuthChanged()
    {
        if (Auth.IsAuthenticated && _project is null && !_loading)
        {
            _loading = true;
            await InvokeAsync(StateHasChanged);
            _project = await Api.GetProjectAsync(Id);
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose() => Auth.OnChange -= OnAuthChanged;

    private void ToggleEdit()
    {
        if (_showEdit) { _showEdit = false; return; }
        _editName = _project!.Name;
        _editPhase = _project.Phase;
        _editDescription = _project.Description ?? "";
        _editError = null;
        _showEdit = true;
    }

    private async Task SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(_editName))
        {
            _editError = "El nombre es obligatorio.";
            return;
        }

        _saving = true;
        _editError = null;

        try
        {
            var desc = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim();
            var updated = await Api.UpdateProjectAsync(Id,
                new UpdateProjectRequest(_editName.Trim(), desc, _editPhase));

            if (updated is not null)
            {
                _project = await Api.GetProjectAsync(Id);
                _showEdit = false;
            }
        }
        catch (Exception ex)
        {
            _editError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDelete()
    {
        var result = await Dialog.ShowMessageBox(
            "Eliminar proyecto",
            $"¿Eliminar \"{_project!.Name}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            await Api.DeleteProjectAsync(Id);
            Nav.NavigateTo("/projects");
        }
    }

    private static Color AreaColor(string area) => area switch
    {
        "Customer" => Color.Info,
        "Solution" => Color.Success,
        "Endeavor" => Color.Warning,
        _ => Color.Default
    };
}
