@page "/"

<PageTitle>Essence MVP</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <MudText Typo="Typo.h3" GutterBottom="true">Essence</MudText>
    <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-8">
        Gestión de proyectos simple y eficiente.
    </MudText>
    <MudStack Row="true" Justify="Justify.Center" Spacing="3">
        <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large">
            Crear cuenta
        </MudButton>
        <MudButton Href="/login" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large">
            Iniciar sesión
        </MudButton>
    </MudStack>
</MudContainer>
