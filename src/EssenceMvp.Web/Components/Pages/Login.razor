@page "/login"
@rendermode InteractiveServer

<PageTitle>Iniciar sesión — Essence</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-8">
        <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">Iniciar sesión</MudText>

        <MudForm @ref="_form">
            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                          InputType="InputType.Email" Class="mb-4" FullWidth="true"
                          Validation="@((Func<string, string?>)FormValidators.Email)"
                          Immediate="true" />

            <MudTextField @bind-Value="_password" Label="Contraseña" Variant="Variant.Outlined"
                          InputType="@_pwdType" Class="mb-4" FullWidth="true"
                          Adornment="Adornment.End" AdornmentIcon="@_pwdIcon"
                          OnAdornmentClick="TogglePwd" />
        </MudForm>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudAlert Severity="@(_isError ? Severity.Error : Severity.Success)" Class="mb-4" Dense="true">
                @_message
            </MudAlert>
        }

        <MudButton OnClick="DoLogin" Variant="Variant.Filled" Color="Color.Primary"
                   FullWidth="true" Disabled="@_loading" Size="Size.Large">
            @(_loading ? "Entrando..." : "Entrar")
        </MudButton>

        <MudText Align="Align.Center" Class="mt-4" Typo="Typo.body2">
            ¿No tienes cuenta? <MudLink Href="/register">Regístrate</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [Inject] ApiClient Api { get; set; } = default!;
    [Inject] AuthState Auth { get; set; } = default!;
    [Inject] StorageService Storage { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] SessionAuthenticationStateProvider AuthProvider { get; set; } = default!;

    private MudForm _form = default!;
    private string _email = "";
    private string _password = "";
    private string? _message;
    private bool _isError;
    private bool _loading;
    private InputType _pwdType = InputType.Password;
    private string _pwdIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePwd()
    {
        if (_pwdType == InputType.Password)
        {
            _pwdType = InputType.Text;
            _pwdIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            _pwdType = InputType.Password;
            _pwdIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private async Task DoLogin()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _loading = true;
        _isError = false;
        _message = null;

        try
        {
            var result = await Api.LoginAsync(new(_email, _password));
            if (result is null)
            {
                _isError = true;
                _message = "Email o contraseña incorrectos";
                return;
            }
            await Storage.SetAsync("essence_session", System.Text.Json.JsonSerializer.Serialize(result));
            Auth.SetSession(result);
            AuthProvider.NotifySessionChanged();
            Nav.NavigateTo("/projects", forceLoad: false);
        }
        catch (Exception ex)
        {
            _isError = true;
            _message = ex.Message;
            await Storage.DevErrorAsync($"[Login] {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
