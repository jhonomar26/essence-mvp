@page "/register"
@rendermode InteractiveServer
@using EssenceMvp.Web.Services

<PageTitle>Crear cuenta — Essence</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-8">
        <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">Crear cuenta</MudText>

        <MudForm @ref="_form">
            <MudTextField @bind-Value="_displayName" Label="Nombre (opcional)" Variant="Variant.Outlined"
                          Class="mb-4" FullWidth="true" />

            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                          InputType="InputType.Email" Class="mb-4" FullWidth="true"
                          Validation="@((Func<string, string?>)FormValidators.Email)"
                          Immediate="true" />

            <MudTextField @bind-Value="_password" Label="Contraseña (mín. 6 caracteres)" Variant="Variant.Outlined"
                          InputType="InputType.Password" Class="mb-4" FullWidth="true" />
        </MudForm>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudAlert Severity="@(_isError ? Severity.Error : Severity.Success)" Class="mb-4" Dense="true">
                @_message
            </MudAlert>
        }

        <MudButton OnClick="DoRegister" Variant="Variant.Filled" Color="Color.Primary"
                   FullWidth="true" Disabled="@_loading" Size="Size.Large">
            @(_loading ? "Creando cuenta..." : "Crear cuenta")
        </MudButton>

        <MudText Align="Align.Center" Class="mt-4" Typo="Typo.body2">
            ¿Ya tienes cuenta? <MudLink Href="/login">Inicia sesión</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [Inject] ApiClient Api { get; set; } = default!;
    [Inject] AuthState Auth { get; set; } = default!;
    [Inject] StorageService Storage { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;

    private MudForm _form = default!;
    private string _displayName = "";
    private string _email = "";
    private string _password = "";
    private string? _message;
    private bool _isError;
    private bool _loading;

    private async Task DoRegister()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        if (_password.Length < 6)
        {
            _isError = true;
            _message = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }

        _loading = true;
        _isError = false;
        _message = null;

        try
        {
            var result = await Api.RegisterAsync(
                new RegisterRequest(_email.Trim(), _password,
                    string.IsNullOrWhiteSpace(_displayName) ? null : _displayName.Trim())
            );
            if (result is null) throw new Exception("El servidor no devolvió sesión.");
            await Storage.SetAsync("essence_session",
                System.Text.Json.JsonSerializer.Serialize(result));
            Auth.SetSession(result);
            Nav.NavigateTo("/projects");
        }
        catch (Exception ex)
        {
            _isError = true;
            _message = ex.Message;
            await Storage.DevErrorAsync($"[Register] {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
