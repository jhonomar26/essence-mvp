@page "/projects"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Mis proyectos — Essence</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        Debes <MudLink Href="/login">iniciar sesión</MudLink> para ver tus proyectos.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudText Typo="Typo.h5">Mis proyectos</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenForm(null))">
            Nuevo proyecto
        </MudButton>
    </MudStack>

    @if (_showForm)
    {
        <MudPaper Elevation="2" Class="pa-6 mb-6">
            <MudText Typo="Typo.h6" Class="mb-4">@(_editId.HasValue ? "Editar proyecto" : "Nuevo proyecto")</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formName" Label="Nombre *" Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_formPhase" Label="Fase" Variant="Variant.Outlined"
                               FullWidth="true" Clearable="true">
                        <MudSelectItem T="string" Value="@("Inception")">Inception</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Elaboration")">Elaboration</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Construction")">Construction</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Transition")">Transition</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_formDescription" Label="Descripción" Variant="Variant.Outlined"
                                  FullWidth="true" Lines="2" />
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrWhiteSpace(_formError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_formError</MudAlert>
            }

            <MudStack Row="true" Class="mt-4" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProject" Disabled="@_saving">
                    @(_saving ? "Guardando..." : "Guardar")
                </MudButton>
                <MudButton Variant="Variant.Text" OnClick="CloseForm">Cancelar</MudButton>
            </MudStack>
        </MudPaper>
    }

    @if (_projects is null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_projects.Count == 0 && !_showForm)
    {
        <MudAlert Severity="Severity.Info">
            No tienes proyectos todavía.
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => OpenForm(null))">
                Crear el primero
            </MudButton>
        </MudAlert>
    }
    else if (_projects.Count > 0)
    {
        <MudTable Items="@_projects" Hover="true" Elevation="2" Dense="true">
            <HeaderContent>
                <MudTh>Nombre</MudTh>
                <MudTh>Fase</MudTh>
                <MudTh>Creado</MudTh>
                <MudTh Style="width: 120px"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nombre">@context.Name</MudTd>
                <MudTd DataLabel="Fase">
                    @if (!string.IsNullOrWhiteSpace(context.Phase))
                    {
                        <MudChip Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">@context.Phase</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Creado">@context.CreatedAt.ToString("dd/MM/yyyy")</MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="0" Justify="Justify.FlexEnd">
                        <MudTooltip Text="Ver detalle">
                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                           Color="Color.Default" Href="@($"/projects/{context.Id}")" />
                        </MudTooltip>
                        <MudTooltip Text="Editar">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Secondary" OnClick="@(() => OpenForm(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Eliminar">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => ConfirmDelete(context))" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    [Inject] ApiClient Api { get; set; } = default!;
    [Inject] AuthState Auth { get; set; } = default!;
    [Inject] IDialogService Dialog { get; set; } = default!;

    private List<ProjectDto>? _projects;

    private bool _showForm;
    private int? _editId;
    private string _formName = "";
    private string? _formPhase;
    private string _formDescription = "";
    private string? _formError;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnChange += OnAuthChanged;
        if (Auth.IsAuthenticated)
            _projects = await Api.GetProjectsAsync();
    }

    private async void OnAuthChanged()
    {
        if (Auth.IsAuthenticated && _projects is null)
        {
            _projects = await Api.GetProjectsAsync();
            await InvokeAsync(StateHasChanged);
        }
        else if (!Auth.IsAuthenticated)
        {
            _projects = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose() => Auth.OnChange -= OnAuthChanged;

    private void OpenForm(ProjectDto? project)
    {
        _editId = project?.Id;
        _formName = project?.Name ?? "";
        _formPhase = project?.Phase;
        _formDescription = project?.Description ?? "";
        _formError = null;
        _showForm = true;
    }

    private void CloseForm()
    {
        _showForm = false;
        _formError = null;
    }

    private async Task SaveProject()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            _formError = "El nombre es obligatorio.";
            return;
        }

        _saving = true;
        _formError = null;

        try
        {
            var desc = string.IsNullOrWhiteSpace(_formDescription) ? null : _formDescription.Trim();

            if (_editId.HasValue)
            {
                var updated = await Api.UpdateProjectAsync(_editId.Value,
                    new UpdateProjectRequest(_formName.Trim(), desc, _formPhase));
                if (updated is not null && _projects is not null)
                {
                    var idx = _projects.FindIndex(p => p.Id == _editId.Value);
                    if (idx >= 0) _projects[idx] = updated;
                }
            }
            else
            {
                var created = await Api.CreateProjectAsync(
                    new CreateProjectRequest(_formName.Trim(), desc, _formPhase));
                if (created is not null)
                {
                    _projects ??= new();
                    _projects.Insert(0, created);
                }
            }

            CloseForm();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDelete(ProjectDto project)
    {
        var result = await Dialog.ShowMessageBox(
            "Eliminar proyecto",
            $"¿Eliminar \"{project.Name}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            await Api.DeleteProjectAsync(project.Id);
            _projects?.Remove(project);
        }
    }
}
