@page "/projects"
@rendermode InteractiveServer

<PageTitle>Mis proyectos — Essence</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <MudAlert Severity="Severity.Warning">
        Debes <MudLink Href="/login">iniciar sesión</MudLink> para ver tus proyectos.
    </MudAlert>
}
else if (_projects is null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <MudText Color="Color.Secondary">Cargando proyectos...</MudText>
}
else if (_projects.Count == 0)
{
    <MudAlert Severity="Severity.Info">No tienes proyectos todavía.</MudAlert>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-4">Mis proyectos</MudText>
    <MudGrid>
        @foreach (var project in _projects)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@project.Name</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    @if (!string.IsNullOrWhiteSpace(project.Description))
                    {
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@project.Description</MudText>
                        </MudCardContent>
                    }
                    <MudCardActions>
                        <MudText Typo="Typo.caption" Color="Color.Primary">@(project.Phase ?? "Sin fase")</MudText>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Inject] ApiClient Api { get; set; } = default!;
    [Inject] AuthState Auth { get; set; } = default!;

    private List<ProjectDto>? _projects;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAuthenticated)
            _projects = await Api.GetMyProjectsAsync();
    }
}
