@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer
@inject AuthState Auth
@inject StorageService Storage
@inject ApiClient Api
@inject NavigationManager Nav
@inject SessionAuthenticationStateProvider AuthProvider
@implements IDisposable

@if (Auth.IsAuthenticated)
{
    <MudText Typo="Typo.body2" Class="mr-3 mud-text-secondary d-none d-sm-block">
        @(Auth.DisplayName ?? Auth.Email ?? "Usuario")
    </MudText>
    <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="Logout">Salir</MudButton>
}
else
{
    <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit">Entrar</MudButton>
    <MudButton Href="/register" Variant="Variant.Outlined" Color="Color.Inherit" Class="ml-2">Registrarse</MudButton>
}

@code {
    protected override void OnInitialized()
    {
        Auth.OnChange += OnAuthChanged;
    }

    private void OnAuthChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.OnChange -= OnAuthChanged;
    }

    private async Task Logout()
    {
        if (!string.IsNullOrWhiteSpace(Auth.RefreshToken))
            await Api.LogoutAsync(Auth.RefreshToken);

        Auth.Clear();
        await Storage.RemoveAsync("essence_session");
        AuthProvider.NotifySessionChanged();
        Nav.NavigateTo("/login");
    }
}
