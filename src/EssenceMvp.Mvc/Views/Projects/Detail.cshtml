@using EssenceMvp.Mvc.Helpers
@model ProjectDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Proyectos</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="page-header mb-4">
    <div class="row align-items-start">
        <div class="col">
            <h1 class="page-title mb-2">@Model.Name</h1>
            @if (Model.Phase != null)
            {
                <span class="badge bg-info text-white me-2">@Model.Phase</span>
            }
            <span class="badge @HealthStatusHelper.GetBgClass(Model.OverallHealth)">
                @HealthStatusHelper.GetLabel(Model.OverallHealth)
            </span>
            @if (Model.Description != null)
            {
                <p class="text-muted mt-3 mb-0">@Model.Description</p>
            }
        </div>

        <div class="col-md-auto">
            <div class="card border-0 shadow-sm bg-white">
                <div class="card-body text-center" style="min-width: 180px;">
                    <div class="h4 mb-1" style="color: #0d6efd;">
                        @Model.HealthScore.ToString("F1")%
                    </div>
                    <small class="d-block mb-2 text-muted">@Model.HealthClassification</small>
                    <div class="semaforo @HealthStatusHelper.GetBgClass(Model.OverallHealth)" style="margin: 0.5rem auto; font-size: 0.8rem;">
                        <i class="bi bi-circle-fill d-block"></i>
                    </div>
                    <button id="saveSnapshotBtn" type="button" class="btn btn-sm btn-primary w-100 mt-3" onclick="saveSnapshot()">
                        <i class="bi bi-camera"></i> Guardar Snapshot
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-start gap-3">
            <div style="font-size: 1.75rem; color: #0d6efd;">
                <i class="bi bi-graph-up"></i>
            </div>
            <div class="flex-grow-1">
                <h6 class="card-title mb-2">SEMAT Essence Health Score</h6>
                <div class="row g-3 text-sm">
                    <div class="col-md-4">
                        <div class="text-muted small">Promedio</div>
                        <div class="h6 mb-0">@Model.AverageProgress.ToString("F1")%</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Dispersión</div>
                        <div class="h6 mb-0">@Model.ProgressDispersion.ToString("F1")%</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Penalización</div>
                        <div class="h6 mb-0">@(Math.Round(Model.ProgressDispersion * 0.2m, 2))%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<h5 class="mb-4 fw-semibold">
    <i class="bi bi-grid-3x3-gap"></i> Estados de Alphas
</h5>

<div class="row row-cols-1 row-cols-lg-2 g-4">
    @foreach (var alpha in Model.AlphaProgress)
    {
        <div class="col">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h6 class="card-title mb-1">@alpha.AlphaName</h6>
                                <small class="text-muted">@alpha.AreaOfConcern</small>
                            </div>
                            <span class="badge bg-info text-dark flex-shrink-0 ms-2">
                                @alpha.CurrentStateNumber/@alpha.MaxStateNumber
                            </span>
                        </div>

                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar @(alpha.Progress < 33 ? "bg-danger" : alpha.Progress < 67 ? "bg-warning" : "bg-success")"
                                 role="progressbar"
                                 style="width: @alpha.Progress.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"
                                 aria-valuenow="@((int)alpha.Progress)"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                            </div>
                        </div>

                        <div class="mt-2">
                            @if (alpha.CurrentStateNumber == 0)
                            {
                                <small class="text-muted">
                                    <i class="bi bi-info-circle"></i> No iniciado
                                </small>
                            }
                            else
                            {
                                <small class="text-muted d-flex justify-content-between">
                                    <span>Estado: <strong>@alpha.CurrentStateName</strong></span>
                                    <span>Progreso: <strong>@alpha.Progress.ToString("F1")%</strong></span>
                                </small>
                            }
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary btn-sm align-self-start mt-auto"
                            data-bs-toggle="modal" data-bs-target="#evaluateAlphaModal_@alpha.AlphaId">
                        <i class="bi bi-pencil-square"></i> Evaluar Alpha
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-5">
    <h5 class="mb-3 text-muted fw-semibold">
        <i class="bi bi-clock-history"></i> Historial de Snapshots
    </h5>

    <div class="accordion" id="snapshotAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#snapshotPanel">
                    <span id="snapshotCount">@(((List<SnapshotSummaryDto>)ViewBag.RecentSnapshots)?.Count ?? 0) </span>
                     snapshot(s) registrado(s)
                </button>
            </h2>
            <div id="snapshotPanel" class="accordion-collapse collapse" data-bs-parent="#snapshotAccordion">
                <div class="accordion-body p-3">
                    @{
                        var recentSnapshots = (List<SnapshotSummaryDto>)ViewBag.RecentSnapshots ?? new List<SnapshotSummaryDto>();
                    }
                    @await Html.PartialAsync("_SnapshotHistoryPanel", recentSnapshots)
                </div>
            </div>
        </div>
    </div>
</div>

@* Modales de evaluación *@
@{
    var alphaChecklists = (Dictionary<int, List<AlphaChecklistDto>>)ViewBag.AlphaChecklists;
    if (alphaChecklists != null)
    {
        foreach (var alpha in Model.AlphaProgress)
        {
            if (alphaChecklists.TryGetValue(alpha.AlphaId, out var checklists))
            {
                await Html.RenderPartialAsync("_AlphaEvaluationModal", (Model.Id, alpha.AlphaId, alpha.AlphaName, checklists));
            }
        }
    }
}

<script>
async function saveSnapshot() {
    const projectId = @Model.Id;
    const btn = document.getElementById('saveSnapshotBtn');

    btn.disabled = true;
    const originalContent = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';

    try {
        const response = await fetch(`/projects/${projectId}/snapshots`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
            showToast('Snapshot guardado correctamente', 'success');
            setTimeout(() => location.reload(), 1500);
        } else if (response.status === 401 || response.status === 403) {
            showToast('No tienes permiso para guardar snapshots en este proyecto', 'warning');
        } else {
            showToast('Error al guardar snapshot', 'error');
        }
    } catch (error) {
        console.error('Error:', error);
        showToast('Error de conexión', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalContent;
    }
}

function deleteSnapshot(snapshotId) {
    showConfirmModal(
        'Eliminar Snapshot',
        '¿Estás seguro que deseas eliminar este snapshot? Esta acción no se puede deshacer.',
        async () => {
            const projectId = @Model.Id;
            const btn = event.target.closest('button');
            btn.disabled = true;

            try {
                const response = await fetch(`/projects/${projectId}/snapshots/${snapshotId}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    showToast('Snapshot eliminado correctamente', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else if (response.status === 404) {
                    showToast('Snapshot no encontrado', 'warning');
                } else {
                    showToast('Error al eliminar snapshot', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error de conexión', 'error');
            } finally {
                btn.disabled = false;
            }
        }
    );
}
</script>
