@model ProjectDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    var (healthBg, healthText) = Model.OverallHealth switch
    {
        HealthStatus.Green => ("bg-success", "text-white"),
        HealthStatus.Yellow => ("bg-warning", "text-dark"),
        _ => ("bg-danger", "text-white")
    };
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Proyectos</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4">

    <div>
        <h2 class="mb-1">@Model.Name</h2>

        @if (Model.Phase != null)
        {
            <span class="badge bg-secondary me-2">@Model.Phase</span>
        }

        @if (Model.Description != null)
        {
            <p class="text-muted mt-2 mb-0">@Model.Description</p>
        }
    </div>

    <div class="text-center ms-4">
        <div style="padding: 1rem; background: #f8f9fa; border-radius: 8px; min-width: 120px;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #212529;">
                @Model.HealthScore.ToString("F1")%
            </div>
            <small class="d-block mt-1 fw-semibold text-primary">@Model.HealthClassification</small>
            <div class="semaforo @healthBg @healthText" style="margin-top: 0.5rem; font-size: 1rem;">
                <i class="bi bi-circle-fill d-block"></i>
            </div>
        </div>
    </div>

</div>

<div class="alert alert-info" role="alert">
    <strong>SEMAT Essence Health Score:</strong> Promedio de progreso Alphas: @Model.AverageProgress.ToString("F1")%
    • Dispersión: @Model.ProgressDispersion.ToString("F1")% • Penalización: @(Math.Round(Model.ProgressDispersion * 0.2m, 2))%
</div>

<h5 class="mb-3 text-muted fw-semibold">
    <i class="bi bi-grid-3x3-gap"></i> Estados de Alphas
</h5>

<div class="row row-cols-1 row-cols-md-2 g-3">

@foreach (var alpha in Model.AlphaProgress)
{
    <div class="col">
        <div class="card border-0 shadow-sm">
            <div class="card-body py-3">

                <div class="d-flex justify-content-between align-items-start mb-2">

                    <div>
                        <h6 class="mb-0 fw-semibold">@alpha.AlphaName</h6>
                        <small class="text-muted">@alpha.AreaOfConcern</small>
                    </div>

                    <span class="badge bg-info text-dark flex-shrink-0 ms-2">
                        @alpha.CurrentStateNumber / @alpha.MaxStateNumber
                    </span>

                </div>

                <div class="progress mt-2" style="height: 8px;">
                    <div class="progress-bar bg-primary"
                         role="progressbar"
                         style="width: @alpha.Progress%"
                         aria-valuenow="@((int)alpha.Progress)"
                         aria-valuemin="0"
                         aria-valuemax="100">
                    </div>
                </div>

                <small class="text-muted mt-1 d-block">
                    @if (alpha.CurrentStateNumber == 0)
                    {
                        <span>Estado: No iniciado</span>
                    }
                    else
                    {
                        <span>Estado: @alpha.CurrentStateName • Progreso: @alpha.Progress.ToString("F1")%</span>
                    }
                </small>

                <div class="mt-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#evaluateAlphaModal_@alpha.AlphaId">
                        <i class="bi bi-pencil-square"></i> Evaluar
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@* Modales de evaluación *@
@{
    var alphaChecklists = (Dictionary<int, List<AlphaChecklistDto>>)ViewBag.AlphaChecklists;
    if (alphaChecklists != null)
    {
        foreach (var alpha in Model.AlphaProgress)
        {
            if (alphaChecklists.TryGetValue(alpha.AlphaId, out var checklists))
            {
                await Html.RenderPartialAsync("_AlphaEvaluationModal", (Model.Id, alpha.AlphaId, alpha.AlphaName, checklists));
            }
        }
    }
}

</div>