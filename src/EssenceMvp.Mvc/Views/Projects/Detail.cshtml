@model ProjectDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    var (healthBg, healthText) = Model.OverallHealth switch
    {
        HealthStatus.green => ("bg-success", "text-white"),
        HealthStatus.yellow => ("bg-warning", "text-dark"),
        _ => ("bg-danger", "text-white")
    };
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Proyectos</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4">

    <div>
        <h2 class="mb-1">@Model.Name</h2>

        @if (Model.Phase != null)
        {
            <span class="badge bg-secondary me-2">@Model.Phase</span>
        }

        @if (Model.Description != null)
        {
            <p class="text-muted mt-2 mb-0">@Model.Description</p>
        }
    </div>

    <div class="text-center ms-4">
        <div style="padding: 1rem; background: #f8f9fa; border-radius: 8px; min-width: 120px;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #212529;">
                @Model.HealthScore.ToString("F1")%
            </div>
            <small class="d-block mt-1 fw-semibold text-primary">@Model.HealthClassification</small>
            <div class="semaforo @healthBg @healthText" style="margin-top: 0.5rem; font-size: 1rem;">
                <i class="bi bi-circle-fill d-block"></i>
            </div>
            <button id="saveSnapshotBtn" type="button" class="btn btn-sm btn-primary mt-3 w-100" onclick="saveSnapshot()">
                <i class="bi bi-camera"></i> Guardar
            </button>
        </div>
    </div>

</div>

<div class="card border-0 shadow-sm bg-light mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center gap-3">
            <div style="font-size: 1.5rem; color: #0d6efd;">
                <i class="bi bi-graph-up"></i>
            </div>
            <div>
                <h6 class="card-title mb-1">SEMAT Essence Health Score</h6>
                <small class="text-muted">
                    Promedio: <strong>@Model.AverageProgress.ToString("F1")%</strong>
                    • Dispersión: <strong>@Model.ProgressDispersion.ToString("F1")%</strong>
                    • Penalización: <strong>@(Math.Round(Model.ProgressDispersion * 0.2m, 2))%</strong>
                </small>
            </div>
        </div>
    </div>
</div>

<h5 class="mb-3 text-muted fw-semibold">
    <i class="bi bi-grid-3x3-gap"></i> Estados de Alphas
</h5>

<div class="row row-cols-1 row-cols-md-2 g-3">

@foreach (var alpha in Model.AlphaProgress)
{
    <div class="col">
        <div class="card border-0 shadow-sm">
            <div class="card-body py-3">

                <div class="d-flex justify-content-between align-items-start mb-2">

                    <div>
                        <h6 class="mb-0 fw-semibold">@alpha.AlphaName</h6>
                        <small class="text-muted">@alpha.AreaOfConcern</small>
                    </div>

                    <span class="badge bg-info text-dark flex-shrink-0 ms-2">
                        @alpha.CurrentStateNumber / @alpha.MaxStateNumber
                    </span>

                </div>

                <div class="progress mt-2" style="height: 8px;">
                    <div class="progress-bar bg-primary"
                         role="progressbar"
                         style="width: @alpha.Progress%"
                         aria-valuenow="@((int)alpha.Progress)"
                         aria-valuemin="0"
                         aria-valuemax="100">
                    </div>
                </div>

                <small class="text-muted mt-1 d-block">
                    @if (alpha.CurrentStateNumber == 0)
                    {
                        <span>Estado: No iniciado</span>
                    }
                    else
                    {
                        <span>Estado: @alpha.CurrentStateName • Progreso: @alpha.Progress.ToString("F1")%</span>
                    }
                </small>

                <div class="mt-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#evaluateAlphaModal_@alpha.AlphaId">
                        <i class="bi bi-pencil-square"></i> Evaluar
                    </button>
                </div>

            </div>
        </div>
    </div>
}

</div>

<div class="mt-5">
    <h5 class="mb-3 text-muted fw-semibold">
        <i class="bi bi-clock-history"></i> Historial de Snapshots
    </h5>

    <div class="accordion" id="snapshotAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#snapshotPanel">
                    <span id="snapshotCount">@(((List<SnapshotSummaryDto>)ViewBag.RecentSnapshots)?.Count ?? 0) </span>
                     snapshot(s) registrado(s)
                </button>
            </h2>
            <div id="snapshotPanel" class="accordion-collapse collapse" data-bs-parent="#snapshotAccordion">
                <div class="accordion-body p-3">
                    @{
                        var recentSnapshots = (List<SnapshotSummaryDto>)ViewBag.RecentSnapshots ?? new List<SnapshotSummaryDto>();
                    }
                    @await Html.PartialAsync("_SnapshotHistoryPanel", recentSnapshots)
                </div>
            </div>
        </div>
    </div>
</div>

@* Modales de evaluación *@
@{
    var alphaChecklists = (Dictionary<int, List<AlphaChecklistDto>>)ViewBag.AlphaChecklists;
    if (alphaChecklists != null)
    {
        foreach (var alpha in Model.AlphaProgress)
        {
            if (alphaChecklists.TryGetValue(alpha.AlphaId, out var checklists))
            {
                await Html.RenderPartialAsync("_AlphaEvaluationModal", (Model.Id, alpha.AlphaId, alpha.AlphaName, checklists));
            }
        }
    }
}

<script>
async function saveSnapshot() {
    const projectId = @Model.Id;
    const btn = document.getElementById('saveSnapshotBtn');

    btn.disabled = true;
    const originalContent = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';

    try {
        const response = await fetch(`/projects/${projectId}/snapshots`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
            showToast('Snapshot guardado correctamente', 'success');
            setTimeout(() => location.reload(), 1500);
        } else if (response.status === 401 || response.status === 403) {
            showToast('No tienes permiso para guardar snapshots en este proyecto', 'warning');
        } else {
            showToast('Error al guardar snapshot', 'error');
        }
    } catch (error) {
        console.error('Error:', error);
        showToast('Error de conexión', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalContent;
    }
}

async function deleteSnapshot(snapshotId) {
    if (!confirm('¿Estás seguro que deseas eliminar este snapshot?')) return;

    const projectId = @Model.Id;
    const btn = event.target.closest('button');
    btn.disabled = true;

    try {
        const response = await fetch(`/projects/${projectId}/snapshots/${snapshotId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
            showToast('Snapshot eliminado correctamente', 'success');
            setTimeout(() => location.reload(), 1500);
        } else if (response.status === 404) {
            showToast('Snapshot no encontrado', 'warning');
        } else {
            showToast('Error al eliminar snapshot', 'error');
        }
    } catch (error) {
        console.error('Error:', error);
        showToast('Error de conexión', 'error');
    } finally {
        btn.disabled = false;
    }
}
</script>
