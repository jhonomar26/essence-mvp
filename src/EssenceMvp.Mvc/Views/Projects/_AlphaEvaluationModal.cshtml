@model (int ProjectId, int AlphaId, string AlphaName, List<AlphaChecklistDto> Checklists)

<div class="modal fade" id="evaluateAlphaModal_@Model.AlphaId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Evaluar: @Model.AlphaName</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="evalForm_@Model.AlphaId" method="post" action="/evaluation/alpha" onsubmit="submitEvaluation(event, @Model.AlphaId)">
                <div class="modal-body">
                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                    <input type="hidden" name="alphaId" value="@Model.AlphaId" />

                    @if (Model.Checklists.Any())
                    {
                        @foreach (var stateChecklist in Model.Checklists)
                        {
                            <div class="mb-4">
                                <h6 class="text-primary fw-bold mb-3">
                                    <span class="badge bg-info text-dark me-2">Estado @stateChecklist.StateNumber</span>
                                    @stateChecklist.StateName
                                </h6>
                                <div class="list-group list-group-flush">
                                    @foreach (var criterion in stateChecklist.Criteria)
                                    {
                                        <div class="list-group-item d-flex align-items-start gap-2">
                                            <input type="checkbox"
                                                   class="form-check-input mt-1"
                                                   id="checklist_@criterion.Id"
                                                   value="@criterion.Id"
                                                   data-checklist-id="@criterion.Id"
                                                   @(criterion.IsAchieved ? "checked" : "") />
                                            <label for="checklist_@criterion.Id" class="form-check-label flex-grow-1 mb-0">
                                                @criterion.CriterionText
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No hay criterios para evaluar.</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar Evaluación</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Envía evaluación a servidor: guarda respuestas + recalcula estado
function submitEvaluation(e, alphaId) {
    e.preventDefault();

    const form = document.getElementById('evalForm_' + alphaId);
    const formData = new FormData(form);

    // Recopila estado de todos los checkboxes
    const answers = [];
    document.querySelectorAll(`#evalForm_${alphaId} input[type="checkbox"][data-checklist-id]`).forEach(cb => {
        const checklistId = parseInt(cb.dataset.checklistId);
        answers.push({
            stateChecklistId: checklistId,
            isAchieved: cb.checked,
            notes: null
        });
    });

    const projectId = parseInt(formData.get('projectId'));
    const body = {
        projectId: projectId,
        alphaId: alphaId,
        answers: answers
    };

    // POST a AlphaEvaluationController.Evaluate()
    fetch('/evaluation/alpha', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(body)
    })
    .then(r => r.json())
    .then(data => {
        // Respuesta: { CurrentStateNumber, CurrentStateName }
        console.log('Evaluación guardada:', data);
        const modal = bootstrap.Modal.getInstance(document.getElementById('evaluateAlphaModal_' + alphaId));
        modal?.hide();
        location.reload();  // Recarga página para ver semáforo actualizado
    })
    .catch(err => {
        console.error('Error:', err);
        alert('Error al guardar la evaluación');
    });
}
</script>
