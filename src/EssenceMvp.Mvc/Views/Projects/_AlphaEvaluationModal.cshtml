@model (int ProjectId, int AlphaId, string AlphaName, List<AlphaChecklistDto> Checklists)

<div class="modal fade" id="evaluateAlphaModal_@Model.AlphaId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-pencil-square"></i> Evaluar: @Model.AlphaName
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="evalForm_@Model.AlphaId" method="post" action="/evaluation/alpha" onsubmit="submitEvaluation(event, @Model.AlphaId)">
                <div class="modal-body">
                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                    <input type="hidden" name="alphaId" value="@Model.AlphaId" />

                    @if (Model.Checklists.Any())
                    {
                        @foreach (var stateChecklist in Model.Checklists)
                        {
                            <div class="mb-4 pb-4 border-bottom">
                                <div class="mb-3">
                                    <span class="badge bg-primary me-2">Estado @stateChecklist.StateNumber</span>
                                    <h6 class="d-inline fw-bold">@stateChecklist.StateName</h6>
                                </div>
                                <div class="list-group list-group-flush">
                                    @foreach (var criterion in stateChecklist.Criteria)
                                    {
                                        <div class="list-group-item px-0 py-2">
                                            <div class="form-check">
                                                <input type="checkbox"
                                                       class="form-check-input"
                                                       id="checklist_@criterion.Id"
                                                       value="@criterion.Id"
                                                       data-checklist-id="@criterion.Id"
                                                       @(criterion.IsAchieved ? "checked" : "") />
                                                <label for="checklist_@criterion.Id" class="form-check-label">
                                                    @criterion.CriterionText
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle"></i> No hay criterios para evaluar.
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2"></i> Guardar Evaluación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function submitEvaluation(e, alphaId) {
    e.preventDefault();

    const form = document.getElementById('evalForm_' + alphaId);
    const formData = new FormData(form);

    const answers = [];
    document.querySelectorAll(`#evalForm_${alphaId} input[type="checkbox"][data-checklist-id]`).forEach(cb => {
        const checklistId = parseInt(cb.dataset.checklistId);
        answers.push({
            stateChecklistId: checklistId,
            isAchieved: cb.checked,
            notes: null
        });
    });

    const projectId = parseInt(formData.get('projectId'));
    const body = {
        projectId: projectId,
        alphaId: alphaId,
        answers: answers
    };

    fetch('/evaluation/alpha', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    })
    .then(r => r.json())
    .then(data => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('evaluateAlphaModal_' + alphaId));
        modal?.hide();
        showToast('Evaluación guardada correctamente', 'success');
        setTimeout(() => location.reload(), 1000);
    })
    .catch(err => {
        console.error('Error:', err);
        showToast('Error al guardar la evaluación', 'error');
    });
}
</script>
