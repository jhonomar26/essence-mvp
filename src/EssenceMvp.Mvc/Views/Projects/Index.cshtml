@model List<ProjectSummary>
@{
    ViewData["Title"] = "Proyectos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Mis proyectos</h2>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo proyecto
    </a>
</div

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">

        <i class="bi bi-folder2-open" style="font-size: 3rem;"></i>

        <p class="mt-3 mb-1 fw-semibold">Aún no hay proyectos</p>

        <p class="small">
            Crea tu primer proyecto para comenzar a hacer seguimiento de la salud de Essence.
        </p>

        <a asp-action="Create" class="btn btn-outline-primary mt-2">
            Crear proyecto
        </a>

    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">

        @foreach (var p in Model)
        {
            var (badgeClass, icon) = p.OverallHealth switch
            {
                HealthStatus.green => ("bg-success", "bi-circle-fill"),
                HealthStatus.yellow => ("bg-warning text-dark", "bi-circle-fill"),
                _ => ("bg-danger", "bi-circle-fill")
            };

            <div class="col">

                <div class="card h-100 shadow-sm hover-card">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start mb-2">

                            <h5 class="card-title mb-0">@p.Name</h5>

                            <span class="badge @badgeClass ms-2 flex-shrink-0">
                                <i class="bi @icon me-1" style="font-size: 0.6rem;"></i>
                                @p.OverallHealth
                            </span>

                        </div>

                        @if (p.Phase != null)
                        {
                            <span class="badge bg-secondary mb-2">@p.Phase</span>
                        }

                        <p class="card-text text-muted small mt-1">
                            <i class="bi bi-calendar3"></i> @p.CreatedAt.ToString("dd MMM yyyy")
                        </p>

                    </div>

                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">

                        <a asp-action="Detail" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                            Ver <i class="bi bi-arrow-right"></i>
                        </a>

                        <form asp-action="Delete" asp-route-id="@p.Id" method="post"
                              onsubmit="return confirm('¿Eliminar el proyecto @Html.Raw(p.Name)?')">

                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>

                        </form>

                    </div>

                </div>

            </div>
        }

    </div>
}