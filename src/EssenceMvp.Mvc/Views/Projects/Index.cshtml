@using EssenceMvp.Mvc.Helpers
@model List<ProjectSummary>
@{
    ViewData["Title"] = "Proyectos";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title mb-1">Mis Proyectos</h1>
            <p class="text-muted mb-0">Gestiona y monitorea la salud de tus proyectos Essence</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nuevo Proyecto
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-folder2-open" style="font-size: 3rem; color: #6c757d;"></i>
            <p class="mt-3 mb-1 fw-semibold h5">Aún no hay proyectos</p>
            <p class="text-muted mb-3">
                Crea tu primer proyecto para comenzar a hacer seguimiento de la salud de Essence.
            </p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Crear Primer Proyecto
            </a>
        </div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm hover-card">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="flex-grow-1">
                                <h5 class="card-title mb-1">@p.Name</h5>
                                @if (p.Phase != null)
                                {
                                    <span class="badge bg-info text-white mb-2">@p.Phase</span>
                                }
                            </div>
                            <span class="@HealthStatusHelper.GetBadgeClass(p.OverallHealth) ms-2 flex-shrink-0">
                                <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>
                                @HealthStatusHelper.GetLabel(p.OverallHealth)
                            </span>
                        </div>

                        <p class="card-text text-muted small flex-grow-1 mb-3">
                            <i class="bi bi-calendar3"></i>
                            Creado @p.CreatedAt.ToString("dd MMM yyyy")
                        </p>

                        <div class="d-flex gap-2 pt-2 border-top">
                            <a asp-action="Detail" asp-route-id="@p.Id" class="btn btn-sm btn-primary flex-grow-1">
                                <i class="bi bi-eye"></i> Ver Detalles
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    onclick="showConfirmModal('Eliminar Proyecto', '¿Eliminar &quot;@Html.Raw(p.Name)&quot;? Esta acción no se puede deshacer.', function() { document.getElementById('deleteForm_@p.Id').submit(); })">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <form id="deleteForm_@p.Id" asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:none;"></form>
            </div>
        }
    </div>
}