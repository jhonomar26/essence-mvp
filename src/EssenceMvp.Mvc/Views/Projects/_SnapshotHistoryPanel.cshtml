@model List<SnapshotSummaryDto>

@if (Model.Count == 0)
{
    <div class="alert alert-info small" role="alert">
        <i class="bi bi-info-circle"></i> No hay snapshots registrados
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var snapshot in Model)
        {
            var (healthBg, healthText) = snapshot.GlobalStatus switch
            {
                HealthStatus.green => ("bg-success", "text-white"),
                HealthStatus.yellow => ("bg-warning", "text-dark"),
                _ => ("bg-danger", "text-white")
            };

            <div class="col">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-calendar3"></i>
                                    @snapshot.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </small>
                                <span class="badge @healthBg @healthText">
                                    @snapshot.GlobalStatus
                                </span>
                            </div>
                            <div style="font-size: 1.5rem; font-weight: bold; color: #212529;">
                                @snapshot.HealthScore.ToString("F1")%
                            </div>
                        </div>

                        <small class="text-muted d-block mb-2">
                            @snapshot.Classification
                        </small>

                        @if (snapshot.Alphas.Any())
                        {
                            <div class="mt-3">
                                <small class="text-muted fw-semibold d-block mb-2">Alphas:</small>
                                @foreach (var alpha in snapshot.Alphas)
                                {
                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <small class="text-truncate" style="flex: 1;">
                                                <strong>@alpha.AlphaName</strong>
                                            </small>
                                            <small class="text-muted ms-2" style="white-space: nowrap;">
                                                @alpha.CurrentStateNumber/@alpha.MaxStateNumber
                                            </small>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-primary"
                                                 role="progressbar"
                                                 style="width: @alpha.Progress%"
                                                 aria-valuenow="@((int)alpha.Progress)"
                                                 aria-valuemin="0"
                                                 aria-valuemax="100">
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
