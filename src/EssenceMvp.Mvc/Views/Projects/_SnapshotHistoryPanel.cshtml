@using EssenceMvp.Mvc.Helpers
@model List<SnapshotSummaryDto>

@if (Model.Count == 0)
{
    <div class="alert alert-info small mb-0" role="alert">
        <i class="bi bi-info-circle"></i> No hay snapshots registrados
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var snapshot in Model)
        {
            <div class="col">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <small class="text-muted d-block mb-2">
                                    <i class="bi bi-calendar3"></i>
                                    @snapshot.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </small>
                                <span class="@HealthStatusHelper.GetBadgeClass(snapshot.GlobalStatus)">
                                    @HealthStatusHelper.GetLabel(snapshot.GlobalStatus)
                                </span>
                            </div>
                            <div class="text-end">
                                <div class="h5 mb-2" style="color: #0d6efd;">
                                    @snapshot.HealthScore.ToString("F1")%
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteSnapshot(@snapshot.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>

                        <small class="text-muted d-block mb-3">
                            @snapshot.Classification
                        </small>

                        @if (snapshot.Alphas.Any())
                        {
                            <div class="border-top pt-3">
                                <small class="text-muted fw-semibold d-block mb-2">Alphas:</small>
                                @foreach (var alpha in snapshot.Alphas)
                                {
                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <small class="text-truncate" style="flex: 1;">
                                                <strong>@alpha.AlphaName</strong>
                                            </small>
                                            <small class="text-muted ms-2" style="white-space: nowrap;">
                                                @alpha.CurrentStateNumber/@alpha.MaxStateNumber
                                            </small>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-primary"
                                                 role="progressbar"
                                                 style="width: @alpha.Progress%"
                                                 aria-valuenow="@((int)alpha.Progress)"
                                                 aria-valuemin="0"
                                                 aria-valuemax="100">
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
